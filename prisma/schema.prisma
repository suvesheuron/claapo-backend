// CrewCall Backend — Prisma schema (Part 1 + 2: Auth + Profiles)
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  individual
  company
  vendor
  admin
}

enum OtpType {
  registration
  login
  password_reset
}

enum VendorType {
  all
  equipment
  lighting
  transport
  catering
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  mainUserId   String?   @map("main_user_id") @db.Uuid
  email        String    @unique
  phone        String    @unique
  displayName  String?   @map("display_name")
  passwordHash String    @map("password_hash")
  role         UserRole
  isVerified   Boolean   @default(false) @map("is_verified")
  isActive     Boolean   @default(true) @map("is_active")
  fcmToken              String?   @map("fcm_token")
  notificationPreferences Json?   @map("notification_preferences")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  otpSessions       OtpSession[]       @relation("UserOtpSessions")
  refreshTokens     RefreshToken[]
  individualProfile IndividualProfile?
  companyProfile    CompanyProfile?
  vendorProfile     VendorProfile?
  vendorEquipment  VendorEquipment[]
  availabilitySlots AvailabilitySlot[]
  projectsOwned     Project[]         @relation("CompanyProjects")
  bookingsRequested BookingRequest[]  @relation("RequesterBookings")
  bookingsReceived  BookingRequest[]  @relation("TargetBookings")
  notifications     Notification[]
  invoicesIssued    Invoice[]         @relation("InvoiceIssuer")
  invoicesReceived  Invoice[]         @relation("InvoiceRecipient")
  conversationsAsA  Conversation[]    @relation("ConversationParticipantA")
  conversationsAsB  Conversation[]    @relation("ConversationParticipantB")
  messagesSent      Message[]
  reviewsGiven      Review[]         @relation("ReviewsGiven")
  reviewsReceived   Review[]         @relation("ReviewsReceived")
  portfolioItems    PortfolioItem[]
  mainUser          User?            @relation("UserSubUsers", fields: [mainUserId], references: [id], onDelete: SetNull)
  subUsers          User[]           @relation("UserSubUsers")
  subUserProjectAssignments SubUserProjectAssignment[] @relation("SubUserAssignments")
  accountProjectAssignments SubUserProjectAssignment[] @relation("AccountAssignments")

  @@index([mainUserId])
  @@map("users")
}

model OtpSession {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  otpHash   String   @map("otp_hash")
  type      OtpType
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation("UserOtpSessions", fields: [userId], references: [id], onDelete: SetNull)

  @@map("otp_sessions")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash")
  family    String   @db.Uuid
  expiresAt DateTime @map("expires_at")
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model IndividualProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  displayName    String   @map("display_name")
  bio            String?
  aboutMe        String?  @map("about_me")
  skills         String[] @default([])
  genres         String[] @default([]) @map("genres")
  address        String?  @map("address")
  locationCity   String?  @map("location_city")
  locationState  String?  @map("location_state")
  lat            Float?
  lng            Float?
  dailyBudget    Int?     @map("daily_budget")
  avatarKey      String?  @map("avatar_key")
  showreelKey    String?  @map("showreel_key")
  website        String?  @map("website")
  imdbUrl        String?  @map("imdb_url")
  instagramUrl   String?  @map("instagram_url")
  linkedinUrl    String?  @map("linkedin_url")
  twitterUrl     String?  @map("twitter_url")
  youtubeUrl     String?  @map("youtube_url")
  vimeoUrl       String?  @map("vimeo_url")
  profileScore   Int      @default(0) @map("profile_score")
  isAvailable    Boolean  @default(true) @map("is_available")
  panNumber      String?  @map("pan_number")
  gstNumber      String?  @map("gst_number")
  upiId          String?  @map("upi_id")
  bankAccountName    String?  @map("bank_account_name")
  bankAccountNumber  String?  @map("bank_account_number")
  ifscCode       String?  @map("ifsc_code")
  bankName       String?  @map("bank_name")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("individual_profiles")
}

model CompanyProfile {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  companyName    String   @map("company_name")
  gstNumber      String?  @unique @map("gst_number")
  panNumber      String?  @map("pan_number")
  companyType    String?  @map("company_type")
  skills         String[] @default([])
  website        String?
  imdbUrl        String?  @map("imdb_url")
  instagramUrl   String?  @map("instagram_url")
  linkedinUrl    String?  @map("linkedin_url")
  twitterUrl     String?  @map("twitter_url")
  youtubeUrl     String?  @map("youtube_url")
  vimeoUrl       String?  @map("vimeo_url")
  address        String?  @map("address")
  locationCity   String?  @map("location_city")
  locationState  String?  @map("location_state")
  bankAccountName    String?  @map("bank_account_name")
  bankAccountNumber  String?  @map("bank_account_number")
  ifscCode       String?  @map("ifsc_code")
  bankName       String?  @map("bank_name")
  bio            String?
  aboutUs        String?  @map("about_us")
  logoKey        String?  @map("logo_key")
  isGstVerified  Boolean  @default(false) @map("is_gst_verified")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

model VendorProfile {
  id             String     @id @default(uuid()) @db.Uuid
  userId         String     @unique @map("user_id") @db.Uuid
  companyName    String     @map("company_name")
  vendorType     VendorType @map("vendor_type")
  vendorServiceCategory String? @map("vendor_service_category")
  gstNumber      String?    @unique @map("gst_number")
  panNumber      String?    @map("pan_number")
  isGstVerified  Boolean    @default(false) @map("is_gst_verified")
  website        String?
  imdbUrl        String?    @map("imdb_url")
  instagramUrl   String?    @map("instagram_url")
  linkedinUrl    String?    @map("linkedin_url")
  twitterUrl     String?    @map("twitter_url")
  youtubeUrl     String?    @map("youtube_url")
  vimeoUrl       String?    @map("vimeo_url")
  logoKey        String?    @map("logo_key")
  address        String?
  locationCity   String?    @map("location_city")
  locationState  String?    @map("location_state")
  bankAccountName    String?  @map("bank_account_name")
  bankAccountNumber  String?  @map("bank_account_number")
  ifscCode       String?    @map("ifsc_code")
  bankName       String?    @map("bank_name")
  upiId          String?    @map("upi_id")
  bio            String?
  aboutUs        String?  @map("about_us")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vendor_profiles")
}

model VendorEquipment {
  id           String   @id @default(uuid()) @db.Uuid
  vendorUserId String   @map("vendor_user_id") @db.Uuid
  name         String
  description  String?
  imageUrl     String?  @map("image_url")
  currentCity  String?  @map("current_city")
  dailyBudget  Int?     @map("daily_budget") // paise
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vendor User @relation(fields: [vendorUserId], references: [id], onDelete: Cascade)
  availabilities VendorEquipmentAvailability[]
  bookingRequests BookingRequest[]

  @@index([vendorUserId])
  @@map("vendor_equipment")
}

model VendorEquipmentAvailability {
  id           String   @id @default(uuid()) @db.Uuid
  equipmentId  String   @map("equipment_id") @db.Uuid
  locationCity String   @map("location_city")
  availableFrom DateTime @map("available_from")
  availableTo   DateTime @map("available_to")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  equipment VendorEquipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId, availableFrom, availableTo])
  @@index([locationCity, availableFrom, availableTo])
  @@map("vendor_equipment_availability")
}

enum SlotStatus {
  available
  booked
  blocked
  past_work
}

model AvailabilitySlot {
  id        String     @id @default(uuid()) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  date      DateTime
  status    SlotStatus
  notes     String?
  createdAt DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@index([date, status])
  @@map("availability_slots")
}

enum ProjectStatus {
  draft
  open
  active
  completed
  cancelled
}

enum BookingStatus {
  pending
  accepted
  declined
  locked
  cancel_requested
  cancelled
  expired
}

model Project {
  id              String        @id @default(uuid()) @db.Uuid
  companyUserId   String        @map("company_user_id") @db.Uuid
  title           String
  productionHouseName String?   @map("production_house_name")
  description     String?
  startDate       DateTime      @map("start_date")
  endDate         DateTime      @map("end_date")
  deliveryDate    DateTime?     @map("delivery_date")
  shootDates      DateTime[]    @default([]) @map("shoot_dates")
  shootLocations  String[]      @default([]) @map("shoot_locations")
  locationCity    String?       @map("location_city")
  budget          Int?          @map("budget")
  status          ProjectStatus @default(draft)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  companyUser   User            @relation("CompanyProjects", fields: [companyUserId], references: [id])
  roles         ProjectRole[]
  bookings      BookingRequest[]
  invoices      Invoice[]
  conversations Conversation[]
  subUserAssignments SubUserProjectAssignment[]

  @@index([companyUserId, status])
  @@map("projects")
}

model SubUserProjectAssignment {
  id            String   @id @default(uuid()) @db.Uuid
  accountUserId String   @map("account_user_id") @db.Uuid
  subUserId     String   @map("sub_user_id") @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  accountUser User    @relation("AccountAssignments", fields: [accountUserId], references: [id], onDelete: Cascade)
  subUser     User    @relation("SubUserAssignments", fields: [subUserId], references: [id], onDelete: Cascade)
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([subUserId, projectId])
  @@index([accountUserId, subUserId])
  @@map("sub_user_project_assignments")
}

model ProjectRole {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id") @db.Uuid
  roleName   String   @map("role_name")
  qty        Int      @default(1)
  rateMin    Int?     @map("rate_min")
  rateMax    Int?     @map("rate_max")
  createdAt  DateTime @default(now()) @map("created_at")

  project  Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  bookings BookingRequest[]

  @@map("project_roles")
}

model BookingRequest {
  id                String        @id @default(uuid()) @db.Uuid
  projectId         String        @map("project_id") @db.Uuid
  requesterUserId   String        @map("requester_user_id") @db.Uuid
  targetUserId     String        @map("target_user_id") @db.Uuid
  projectRoleId     String?       @map("project_role_id") @db.Uuid
  vendorEquipmentId String?      @map("vendor_equipment_id") @db.Uuid
  status            BookingStatus @default(pending)
  rateOffered       Int?          @map("rate_offered")
  message           String?
  shootDates        DateTime[]    @default([]) @map("shoot_dates")
  shootLocations    String[]      @default([]) @map("shoot_locations")
  shootDateLocations Json?       @map("shoot_date_locations")
  lockedAt          DateTime?     @map("locked_at")
  respondedAt       DateTime?     @map("responded_at")
  expiresAt         DateTime?     @map("expires_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  cancelledByUserId    String?       @map("cancelled_by_user_id") @db.Uuid
  cancelReason         String?       @map("cancel_reason")
  cancelledAt          DateTime?     @map("cancelled_at")
  cancelRequestReason  String?       @map("cancel_request_reason")
  cancelRequestedAt    DateTime?     @map("cancel_requested_at")
  counterRate          Int?          @map("counter_rate")
  counterMessage       String?       @map("counter_message")
  counterAt            DateTime?     @map("counter_at")

  project      Project     @relation(fields: [projectId], references: [id])
  requester    User        @relation("RequesterBookings", fields: [requesterUserId], references: [id])
  target       User        @relation("TargetBookings", fields: [targetUserId], references: [id])
  projectRole  ProjectRole? @relation(fields: [projectRoleId], references: [id])
  vendorEquipment VendorEquipment? @relation(fields: [vendorEquipmentId], references: [id])
  reviews         Review[]
  contracts       Contract[]
  @@index([projectId])
  @@index([targetUserId, status])
  @@index([requesterUserId, status])
  @@index([vendorEquipmentId])
  @@map("booking_requests")
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

model Invoice {
  id                String        @id @default(uuid()) @db.Uuid
  projectId         String        @map("project_id") @db.Uuid
  issuerUserId      String        @map("issuer_user_id") @db.Uuid
  recipientUserId   String        @map("recipient_user_id") @db.Uuid
  invoiceNumber     String        @unique @map("invoice_number")
  amount            Int           // subtotal in paise (INR × 100)
  gstAmount         Int           @default(0) @map("gst_amount")
  totalAmount       Int           @map("total_amount")
  currency          String        @default("INR")
  status            InvoiceStatus @default(draft)
  dueDate           DateTime?     @map("due_date")
  pdfKey            String?       @map("pdf_key")
  razorpayOrderId   String?       @map("razorpay_order_id")
  paidAt            DateTime?    @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  project    Project             @relation(fields: [projectId], references: [id])
  issuer     User                @relation("InvoiceIssuer", fields: [issuerUserId], references: [id])
  recipient  User                @relation("InvoiceRecipient", fields: [recipientUserId], references: [id])
  lineItems  InvoiceLineItem[]
  attachments InvoiceAttachment[]

  @@map("invoices")
}

model InvoiceAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  invoiceId String   @map("invoice_id") @db.Uuid
  fileKey   String   @map("file_key")
  fileName  String   @map("file_name")
  mimeType  String   @map("mime_type")
  size      Int      // bytes
  createdAt DateTime @default(now()) @map("created_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_attachments")
}

model InvoiceLineItem {
  id          String   @id @default(uuid()) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal  @db.Decimal(10, 2)
  unitPrice   Int      @map("unit_price") // in paise
  amount      Int      // in paise

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_items")
}

model Notification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  type      String    // e.g. booking_request, booking_accepted, invoice_sent
  title     String
  body      String?
  data      Json?     // optional payload for deep link
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// Chat & Messaging (per crewcall_backend_plan.md 4.1.5)
enum MessageType {
  text
  image
  file
  invoice_link
}

model Conversation {
  id             String    @id @default(uuid()) @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  participantA   String    @map("participant_a") @db.Uuid
  participantB   String    @map("participant_b") @db.Uuid
  lastMessageAt  DateTime? @map("last_message_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  participantAUser User @relation("ConversationParticipantA", fields: [participantA], references: [id], onDelete: Cascade)
  participantBUser User @relation("ConversationParticipantB", fields: [participantB], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([projectId, participantA, participantB])
  @@index([participantA, lastMessageAt])
  @@index([participantB, lastMessageAt])
  @@map("conversations")
}

model Message {
  id              String      @id @default(uuid()) @db.Uuid
  conversationId  String      @map("conversation_id") @db.Uuid
  senderId        String      @map("sender_id") @db.Uuid
  type            MessageType @default(text)
  content         String?
  mediaKey        String?     @map("media_key")
  isRead          Boolean     @default(false) @map("is_read")
  isPinned        Boolean     @default(false) @map("is_pinned")
  deletedAt       DateTime?   @map("deleted_at")
  forwardedFromId String?     @map("forwarded_from_id") @db.Uuid
  replyToId       String?     @map("reply_to_id") @db.Uuid
  readAt          DateTime?   @map("read_at")
  createdAt       DateTime    @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies      Message[]    @relation("MessageReplies")

  @@index([conversationId, createdAt])
  @@map("messages")
}

model Review {
  id              String   @id @default(uuid()) @db.Uuid
  bookingId       String   @map("booking_id") @db.Uuid
  reviewerUserId  String   @map("reviewer_user_id") @db.Uuid
  revieweeUserId  String   @map("reviewee_user_id") @db.Uuid
  rating          Int      // 1-5
  text            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  booking  BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer User           @relation("ReviewsGiven", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  reviewee User           @relation("ReviewsReceived", fields: [revieweeUserId], references: [id], onDelete: Cascade)

  @@unique([bookingId, reviewerUserId])
  @@index([revieweeUserId])
  @@map("reviews")
}

model PortfolioItem {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  title     String
  imageKey  String   @map("image_key")
  category  String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
  @@map("portfolio_items")
}

model Contract {
  id            String   @id @default(uuid()) @db.Uuid
  bookingId     String   @map("booking_id") @db.Uuid
  fileKey       String   @map("file_key")
  fileName      String   @map("file_name")
  signedByA     Boolean  @default(false) @map("signed_by_a")
  signedByB     Boolean  @default(false) @map("signed_by_b")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  booking BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("contracts")
}
