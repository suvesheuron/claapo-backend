# CrewCall Backend — copy to .env and fill values (see crewcall_backend_plan.md §13)

# App
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:*

# Database
DATABASE_URL="postgresql://postgres:1234@localhost:5432/crewcall"

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AWS (optional for local)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=crewcall-media-dev
# AWS_CLOUDFRONT_DOMAIN=

# OTP / SMS (optional for local)
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Email (SendGrid)
# SENDGRID_API_KEY=
# SENDGRID_FROM_EMAIL=noreply@crewcall.in
# SENDGRID_FROM_NAME=CrewCall

# Firebase FCM
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Rate limits
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AI_CHAT_HOURLY_LIMIT=20
