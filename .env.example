# CrewCall Backend — copy to .env and fill values (see crewcall_backend_plan.md §13)

# App
NODE_ENV=development
# Demos without SMS: OTP JSON includes devOtp whenever NODE_ENV is not production. Set true to force devOtp in production builds (unsafe for real users).
# EXPOSE_OTP_IN_API=false
PORT=3000
API_BASE_URL=http://localhost:3000
# Comma-separated. Include * to allow any browser Origin (reflect; use with care in production).
# Vercel example: https://your-app.vercel.app — no trailing slash. Multiple: origin1,origin2
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,*

# Database
DATABASE_URL="postgresql://postgres:1234@localhost:5432/crewcall"

# Redis (component vars are preferred; REDIS_URL kept for any legacy reads)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Feature flags (Phase 2/3/4 — see CACHING_QUEUEING_PLAN.md). Default OFF in
# the example file so a fresh checkout starts in legacy behavior; flip to
# "true" individually after verifying each subsystem locally.
#   THROTTLER_ENABLED — Redis-backed @nestjs/throttler. Global default 200/min/IP,
#                       auth routes 10/min/IP, webhooks skipped. (Phase 2)
#   CACHE_ENABLED     — AppCacheService.wrap() reads/writes Redis. Misses or
#                       failures degrade to direct DB. Caches: user identity (1h),
#                       signed URLs (25m), unread-count (30s). (Phase 3)
#   QUEUE_ENABLED     — BullMQ producers enqueue + consumers run. Off = inline
#                       fallback path; bookings.expire cron is not scheduled.
#                       (Phase 4)
THROTTLER_ENABLED=false
CACHE_ENABLED=false
QUEUE_ENABLED=false

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AWS (optional; use Supabase Storage instead for demo)
AWS_REGION=ap-south-1
AWS_S3_BUCKET=crewcall-media-dev
# AWS_CLOUDFRONT_DOMAIN=

# Supabase — Database + Storage (recommended for demo/production)
# Get from: Project Settings > API (URL, service_role key) and Storage (create bucket "uploads")
# DATABASE_URL: use Project Settings > Database > Connection string (URI, include password)
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
# SUPABASE_STORAGE_BUCKET=uploads

# OTP / SMS (optional for local)
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Email
# SES_FROM_EMAIL=noreply@crewcall.in
# SES_REGION=ap-south-1

# Firebase FCM
# FIREBASE_PROJECT_ID=
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=

# OpenAI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Razorpay
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# Rate limits
THROTTLE_TTL=60
THROTTLE_LIMIT=100
AI_CHAT_HOURLY_LIMIT=20
