    "seed:massive": "ts-node prisma/seeds/seed.ts",
    "prisma:studio": "prisma studio",
    "lint": "eslint \"{apps,libs}/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1026.0",
    "@aws-sdk/s3-request-presigner": "^3.1026.0",
